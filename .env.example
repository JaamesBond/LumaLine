# lumaline environment template (COMMITTED — values redacted).
# Local dev: copy to .env and fill from `supabase status` + generated secrets.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<from: supabase status>
SUPABASE_SERVICE_ROLE_KEY=<from: supabase status — service_role, server-only, never ship to client>
SUPABASE_JWT_SECRET=<from: supabase status — signs custom device JWTs>
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
CLICK_SECRET=<random 32-byte hex; HMAC key for click tokens>
ED25519_PRIVATE_KEY_PATH=.secrets/ed25519_private.pem
ED25519_PUBLIC_KEY_PATH=.secrets/ed25519_public.pem
